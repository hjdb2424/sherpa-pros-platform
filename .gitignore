# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

# superpowers brainstorm session files
.superpowers/

# Generated docs PDFs (regenerate with `npm run docs:pdf`)
# docs-pdf/ contains rendered output for the /dataroom route. Track HTML
# (used by Vercel/DO at runtime) and investor-facing PDFs + PPTX (pitch
# deck, slide decks, brand portfolio, one-pager, market sizing, etc).
# Skip the rest — stitched binders are too big, internal-only PDFs add
# noise without value to investors.
/docs-pdf/binders/
/docs-pdf/**/*.pdf
/docs-pdf/**/*.pptx
# Re-include investor-facing PDFs/PPTX
!/docs-pdf/pitch/*.pdf
!/docs-pdf/slides/*.pdf
!/docs-pdf/slides/*.pptx
!/docs-pdf/operations/brand-portfolio.pdf
mobile/.next/

# git worktrees (isolated feature workspaces)
.worktrees/
.env*.local
