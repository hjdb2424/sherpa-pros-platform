NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/select-role
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/pro/dashboard

# Google Maps — Uber-like map interface
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...
NEXT_PUBLIC_GOOGLE_MAPS_MAP_ID=optional_cloud_map_id

# Neon PostgreSQL — connection string from your Neon dashboard
# Serverless driver uses this for both HTTP and WebSocket connections
DATABASE_URL=postgresql://...@ep-xxx.us-east-2.aws.neon.tech/sherpa_pros?sslmode=require

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_CONNECT_CLIENT_ID=ca_...
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Twilio — Masked Communication
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_MESSAGING_SERVICE_SID=MG...

# Google OAuth (optional, mock mode without)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Apple Sign In (optional, mock mode without)
APPLE_CLIENT_ID=your_apple_client_id
APPLE_TEAM_ID=your_apple_team_id
APPLE_KEY_ID=your_apple_key_id

# QuickBooks Online (optional, mock mode without)
QBO_CLIENT_ID=your_qbo_client_id
QBO_CLIENT_SECRET=your_qbo_client_secret
QBO_REDIRECT_URI=http://localhost:3001/api/qbo/callback
QBO_ENVIRONMENT=sandbox

# SerpApi — Home Depot pricing (optional, mock mode without)
SERPAPI_API_KEY=your_serpapi_key

# Zinc API — Home Depot ordering (optional, mock mode without)
ZINC_API_KEY=your_zinc_api_key

# Wisetack — Client financing (optional, mock mode without)
WISETACK_API_KEY=your_wisetack_api_key

# Uber Connect — Gig delivery (optional, mock mode without)
UBER_CONNECT_CLIENT_ID=your_uber_client_id
UBER_CONNECT_CLIENT_SECRET=your_uber_client_secret

# DoorDash Drive — Gig delivery backup (optional, mock mode without)
DOORDASH_DEVELOPER_ID=your_doordash_developer_id
DOORDASH_KEY_ID=your_doordash_key_id
DOORDASH_SIGNING_SECRET=your_doordash_signing_secret

# Tremendous — Pro Rewards (optional, mock mode without)
TREMENDOUS_API_KEY=your_tremendous_api_key
TREMENDOUS_ENVIRONMENT=sandbox

# Social Sync (all optional, mock mode without)
GOOGLE_BUSINESS_API_KEY=your_key
INSTAGRAM_ACCESS_TOKEN=your_token
FACEBOOK_APP_ID=your_app_id
YELP_API_KEY=your_key
