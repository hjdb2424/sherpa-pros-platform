# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# clerk configuration (can include secrets)
/.clerk/

# superpowers brainstorm session files
.superpowers/

# Generated docs PDFs (regenerate with `npm run docs:pdf`)
# docs-pdf/ contains rendered output for the /dataroom route. Track HTML
# (used by Vercel/DO at runtime) but skip heavy binaries that bloat git
# and can be regenerated by `npm run docs:all`.
#
# Track:    .html files (including the hand-curated index)
# Ignore:   .pdf, .pptx, and the stitched binder PDFs directory
/docs-pdf/**/*.pdf
/docs-pdf/**/*.pptx
/docs-pdf/binders/
mobile/.next/

# git worktrees (isolated feature workspaces)
.worktrees/
.env*.local
